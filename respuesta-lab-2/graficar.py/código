# graficar.py
import pandas as pd
import matplotlib.pyplot as plt
import os

RESULTS = "resultados.csv"
FIG_DIR = "figuras"
os.makedirs(FIG_DIR, exist_ok=True)

# Leer resultados desde CSV
df = pd.read_csv(RESULTS)

# Gráfico LSD vs Bitrate por señal y codec
for señal in df["senal"].unique():
    subset = df[df["senal"] == señal].copy()   # filtrar solo esa señal
    subset = subset.sort_values("bitrate")     # ordenar por bitrate
    plt.figure(figsize=(8,5))
    for codec in subset["codec"].unique():
        data = subset[subset["codec"] == codec]
        plt.plot(data["bitrate"], data["LSD"], marker="o", label=codec)
    plt.title(f"LSD vs Bitrate - {señal}")
    plt.xlabel("Bitrate [kbps]")
    plt.ylabel("LSD")
    plt.legend()
    plt.grid(True)
    plt.savefig(os.path.join(FIG_DIR, f"lsd_vs_bitrate_{señal}.png"))
    plt.close()

# Gráfico STOI vs Bitrate (solo voz)
voz = df[df["senal"] == "voz"].copy()
voz = voz.sort_values("bitrate")
plt.figure(figsize=(8,5))
for codec in voz["codec"].unique():
    data = voz[voz["codec"] == codec]
    plt.plot(data["bitrate"], data["STOI"], marker="o", label=codec)
plt.title("STOI vs Bitrate - Voz")
plt.xlabel("Bitrate [kbps]")
plt.ylabel("STOI")
plt.ylim(0.9, 1.0)
plt.legend()
plt.grid(True)
plt.savefig(os.path.join(FIG_DIR, "stoi_vs_bitrate_voz.png"))
plt.close()

print("Figuras generadas en carpeta 'figuras/'")
